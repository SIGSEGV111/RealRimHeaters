<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!--
		Scaling rule:
		2500 W / 21 heat-per-second = 119.047619... W per heat-per-second.

		Supported tiers below are applied to any electrical temperature building that:
		- sits in BuildingsTemperature;
		- has a standard CompProperties_Power/basePowerConsumption node;
		- has a standard CompProperties_TempControl/energyPerSecond node;
		- has positive heat push.

		This keeps compatibility soft: if a target building does not exist, the conditional patch simply does nothing.
	-->

	<!-- 21 EPS -> 2500 W (vanilla Heater, plus any modded heater using vanilla heat push) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
			<value>
				<basePowerConsumption>2500</basePowerConsumption>
			</value>
		</match>
	</Operation>

	<!-- 40 EPS -> 4762 W (WallStuff WallHeater) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 40]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 40]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
			<value>
				<basePowerConsumption>4762</basePowerConsumption>
			</value>
		</match>
	</Operation>

	<!-- 75 EPS -> 8929 W (Quantum Cooling small heater tier) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 75]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 75]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
			<value>
				<basePowerConsumption>8929</basePowerConsumption>
			</value>
		</match>
	</Operation>

	<!-- 400 EPS -> 47619 W (Quantum Cooling large heater tier) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 400]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 400]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
			<value>
				<basePowerConsumption>47619</basePowerConsumption>
			</value>
		</match>
	</Operation>
</Patch>
