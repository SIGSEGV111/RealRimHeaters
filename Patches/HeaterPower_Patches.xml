<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!--
		Active power scaling rule:
		2500 W / 21 heat-per-second = 119.047619... W per heat-per-second.

		Supported tiers below are applied to any electrical temperature building that:
		- sits in BuildingsTemperature;
		- has a standard CompProperties_Power/basePowerConsumption node;
		- has a standard CompProperties_TempControl/energyPerSecond node;
		- has positive heat push.

		Idle power is normalized to 5 W for the same matched heater tiers.
		This keeps compatibility soft: if a target building does not exist, the conditional patch simply does nothing.
	-->

	<!-- 21 EPS -> 2500 W active -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/basePowerConsumption</xpath>
			<value>
				<basePowerConsumption>2500</basePowerConsumption>
			</value>
		</match>
	</Operation>

	<!-- 21 EPS -> 5 W idle (replace existing) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/idlePowerDraw and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/idlePowerDraw</xpath>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power"]/idlePowerDraw and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power"]/idlePowerDraw</xpath>
			<value>
				<idlePowerDraw>5</idlePowerDraw>
			</value>
		</match>
	</Operation>

	<!-- 21 EPS -> 5 W idle (add when absent) -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power" and not(idlePowerDraw)]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power" and not(idlePowerDraw)]</xpath>
		<match Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[thingCategories/li = "BuildingsTemperature" and comps/li[@Class = "CompProperties_Power" and not(idlePowerDraw)]/basePowerConsumption and comps/li[@Class = "CompProperties_TempControl"]/energyPerSecond = 21]/comps/li[@Class = "CompProperties_Power" and not(idlePowerDraw)]</xpath>
			<value>
				<idlePowerDraw>5</idlePowerDraw>
			</value>
		</match>
	</Operation>

